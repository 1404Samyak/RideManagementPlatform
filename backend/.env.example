# This file is a template for backend/.env.
# Copy it as backend/.env only if you want to override the default local values.
# backend/.env is ignored by Git because it can contain private credentials.
#
# The project is configured to use local PostgreSQL by default for faster
# development and reproducible evaluation. Keep this example file in GitHub so
# teammates understand the optional environment variable structure.

# JDBC URL for local PostgreSQL.
DATABASE_URL=jdbc:postgresql://localhost:5432/ride_management_db

# Local database username.
DATABASE_USERNAME=ride_user

# Local database password.
DATABASE_PASSWORD=ride_password

# Secret used to sign JWT tokens. Use any long random string for local work.
JWT_SECRET=local-campus-ride-secret-change-if-needed
